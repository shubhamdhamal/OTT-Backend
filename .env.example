# ============================================================================
# NO REDIS/CELERY REQUIRED!
# ============================================================================
# Remove any REDIS_URL or CELERY configuration
# Video encoding is now synchronous

# FFmpeg Path (optional, if not in system PATH)
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

# Media Files
MEDIA_ROOT=/var/media
MEDIA_URL=/media/

# Email Configuration (for notifications)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/hls_streaming.log

# ============================================================================
# NOTES
# ============================================================================
# 1. Create R2 API token at: https://dash.cloudflare.com/?to=/:account/storage/r2/api-tokens
# 2. Create bucket first in R2 dashboard
# 3. Video encoding will block the upload endpoint (30+ mins for large videos)
# 4. All HLS files are uploaded to R2 and local temp files are deleted
# 5. Set HTTP timeout to 30+ minutes at your load balancer

